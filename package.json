{
  "name": "astryx-sheet",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "An Astryx-powered virtual spreadsheet editor prototype with large-grid virtualization, formulas, selection, resizing, and ref-driven interaction loops.",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "sideEffects": [
    "./src/styles.css"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node --test"
  },
  "keywords": [
    "astryx",
    "spreadsheet",
    "react",
    "virtualization",
    "design-system"
  ],
  "author": "DJ Petersen",
  "license": "MIT",
  "dependencies": {
    "@astryxdesign/core": "0.1.1",
    "@astryxdesign/theme-butter": "^0.1.1",
    "@astryxdesign/theme-chocolate": "^0.1.1",
    "@astryxdesign/theme-gothic": "^0.1.1",
    "@astryxdesign/theme-matcha": "^0.1.1",
    "@astryxdesign/theme-neutral": "^0.1.1",
    "@astryxdesign/theme-stone": "^0.1.1",
    "@astryxdesign/theme-y2k": "0.1.1",
    "@stylexjs/stylex": "^0.18.3",
    "@vitejs/plugin-react": "latest",
    "lucide-react": "^1.21.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "vite": "latest"
  }
}
